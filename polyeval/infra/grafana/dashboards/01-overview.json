{
  "uid": "polyeval-overview",
  "title": "PolyEval — Overview",
  "tags": ["polyeval"],
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Submissions / min",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "sum(rate(api_submissions_total[2m])) * 60", "legendFormat": "submissions/min"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Jobs Active",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 3}, {"color": "red", "value": 8}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "scheduler_jobs_active", "legendFormat": "active"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate (5m)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "rate(scheduler_jobs_failed_total[5m]) / (rate(scheduler_jobs_dispatched_total[5m]) + 0.001)", "legendFormat": "error_rate"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cache Hit Rate (5m)",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.3}, {"color": "green", "value": 0.6}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "rate(api_cache_hits_total[5m]) / (rate(api_cache_hits_total[5m]) + rate(api_cache_misses_total[5m]) + 0.001)", "legendFormat": "hit_rate"}]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Submission Rate by Language",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"legend": {"displayMode": "list"}},
      "targets": [{"expr": "rate(api_submissions_total[2m])", "legendFormat": "{{language}}"}]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Job Dispatch Rate",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"legend": {"displayMode": "list"}},
      "targets": [
        {"expr": "rate(scheduler_jobs_dispatched_total[2m])", "legendFormat": "dispatched"},
        {"expr": "rate(scheduler_jobs_failed_total[2m])", "legendFormat": "failed"}
      ]
    },
    {
      "id": 7,
      "type": "histogram",
      "title": "Correctness Score Distribution",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "targets": [{"expr": "aggregator_correctness_score_bucket", "legendFormat": "{{le}}"}]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Scoring Duration p50 / p95",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(aggregator_scoring_duration_seconds_bucket[5m]))", "legendFormat": "p50"},
        {"expr": "histogram_quantile(0.95, rate(aggregator_scoring_duration_seconds_bucket[5m]))", "legendFormat": "p95"}
      ]
    }
  ]
}
