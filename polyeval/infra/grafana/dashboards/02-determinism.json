{
  "uid": "polyeval-determinism",
  "title": "PolyEval — Determinism Health",
  "tags": ["polyeval"],
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Non-Deterministic Submissions (1h)",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "increase(aggregator_non_deterministic_total[1h])", "legendFormat": "non_det count"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Non-Deterministic Rate (5m)",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 0.02}, {"color": "red", "value": 0.1}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "rate(aggregator_non_deterministic_total[5m]) / (rate(aggregator_scored_total[5m]) + 0.001)", "legendFormat": "non_det_rate"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Sandbox Violations (1h)",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "increase(aggregator_sandbox_violations_total[1h])", "legendFormat": "violations"}]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Non-Deterministic Rate Over Time by Language",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "options": {"legend": {"displayMode": "list"}},
      "targets": [{"expr": "rate(aggregator_non_deterministic_total[5m]) / (rate(aggregator_scored_total[5m]) + 0.001)", "legendFormat": "{{language}}"}]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Sandbox Violations by Language",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"legend": {"displayMode": "list"}},
      "targets": [{"expr": "rate(aggregator_sandbox_violations_total[5m])", "legendFormat": "{{language}}"}]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Scheduler Sandbox Violations by Language",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"legend": {"displayMode": "list"}},
      "targets": [{"expr": "rate(scheduler_sandbox_violations_total[5m])", "legendFormat": "{{language}}"}]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Non-Determinism Events (Loki)",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 8},
      "datasource": {"uid": "loki", "type": "loki"},
      "options": {"dedupStrategy": "none", "enableLogDetails": true},
      "targets": [{"expr": "{service=\"polyeval-aggregator\"} |= \"non_deterministic\""}]
    }
  ]
}
