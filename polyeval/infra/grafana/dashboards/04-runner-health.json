{
  "uid": "polyeval-runners",
  "title": "PolyEval — Runner Health",
  "tags": ["polyeval"],
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Trial p50 Wall Time",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 5}, {"color": "red", "value": 15}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "histogram_quantile(0.50, sum(rate(scheduler_trial_wall_seconds_bucket[5m])) by (le))", "legendFormat": "p50"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Trial p95 Wall Time",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 15}, {"color": "red", "value": 30}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(scheduler_trial_wall_seconds_bucket[5m])) by (le))", "legendFormat": "p95"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Jobs Failed (5m)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "increase(scheduler_jobs_failed_total[5m])", "legendFormat": "failed"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Sandbox Violations (1h)",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "increase(scheduler_sandbox_violations_total[1h])", "legendFormat": "violations"}]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Trial Wall Time p50/p95 by Language",
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"legend": {"displayMode": "table", "calcs": ["lastNotNull"]}},
      "targets": [
        {"expr": "histogram_quantile(0.50, rate(scheduler_trial_wall_seconds_bucket[5m]))", "legendFormat": "p50 {{language}}"},
        {"expr": "histogram_quantile(0.95, rate(scheduler_trial_wall_seconds_bucket[5m]))", "legendFormat": "p95 {{language}}"}
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Dispatched vs Failed Jobs",
      "gridPos": {"x": 0, "y": 12, "w": 12, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"legend": {"displayMode": "list"}},
      "targets": [
        {"expr": "rate(scheduler_jobs_dispatched_total[2m])", "legendFormat": "dispatched/s"},
        {"expr": "rate(scheduler_jobs_failed_total[2m])", "legendFormat": "failed/s"}
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Sandbox Violations Over Time by Language",
      "gridPos": {"x": 12, "y": 12, "w": 12, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"legend": {"displayMode": "list"}},
      "targets": [{"expr": "rate(scheduler_sandbox_violations_total[5m])", "legendFormat": "{{language}}"}]
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Scheduler Logs (Loki)",
      "gridPos": {"x": 0, "y": 20, "w": 24, "h": 8},
      "datasource": {"uid": "loki", "type": "loki"},
      "options": {"dedupStrategy": "none", "enableLogDetails": true},
      "targets": [{"expr": "{service=\"polyeval-scheduler\"} |= \"\""}]
    }
  ]
}
