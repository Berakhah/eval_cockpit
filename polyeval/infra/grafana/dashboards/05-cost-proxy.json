{
  "uid": "polyeval-cost",
  "title": "PolyEval — Cost Proxy",
  "tags": ["polyeval"],
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Submissions (24h)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "increase(api_submissions_total[24h])", "legendFormat": "total"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total CPU-seconds (24h)",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "increase(scheduler_trial_wall_seconds_sum[24h])", "legendFormat": "cpu-seconds proxy"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Wall Time / Trial (5m)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 10}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "rate(scheduler_trial_wall_seconds_sum[5m]) / (rate(scheduler_trial_wall_seconds_count[5m]) + 0.001)", "legendFormat": "avg_wall_s"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Compile-Phase Trials (24h)",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "increase(api_submissions_total{language=~\"rust|java|cpp\"}[24h])", "legendFormat": "two-phase"}]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Submissions by Language (24h)",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 10},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"pieType": "pie", "legend": {"displayMode": "table", "placement": "right"}},
      "targets": [{"expr": "increase(api_submissions_total[24h])", "legendFormat": "{{language}}"}]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cumulative CPU-seconds by Language",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 10},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"legend": {"displayMode": "table", "calcs": ["sum"]}},
      "targets": [{"expr": "increase(scheduler_trial_wall_seconds_sum[1h])", "legendFormat": "{{language}}"}]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Submission Rate by Language",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"legend": {"displayMode": "list"}},
      "targets": [{"expr": "rate(api_submissions_total[5m])", "legendFormat": "{{language}}"}]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Wall-Time Throughput (CPU-cost proxy)",
      "gridPos": {"x": 0, "y": 22, "w": 24, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"legend": {"displayMode": "list"}},
      "targets": [
        {"expr": "rate(scheduler_trial_wall_seconds_sum[5m])", "legendFormat": "wall_s/s ({{language}})"}
      ]
    }
  ]
}
