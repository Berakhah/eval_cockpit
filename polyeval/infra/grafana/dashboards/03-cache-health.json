{
  "uid": "polyeval-cache",
  "title": "PolyEval — Cache Health",
  "tags": ["polyeval"],
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Cache Hit Rate (5m)",
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.3}, {"color": "green", "value": 0.6}]},
          "color": {"mode": "thresholds"}
        }
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "rate(api_cache_hits_total[5m]) / (rate(api_cache_hits_total[5m]) + rate(api_cache_misses_total[5m]) + 0.001)", "legendFormat": "hit_rate"}]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Cache Hits (1h)",
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "increase(api_cache_hits_total[1h])", "legendFormat": "hits"}]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Cache Misses (1h)",
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "increase(api_cache_misses_total[1h])", "legendFormat": "misses"}]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Replay Savings (1h)",
      "gridPos": {"x": 8, "y": 4, "w": 16, "h": 4},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "increase(api_cache_hits_total[1h])", "legendFormat": "compute jobs saved"}]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cache Hits vs Misses Over Time",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"legend": {"displayMode": "list"}},
      "targets": [
        {"expr": "rate(api_cache_hits_total[2m])", "legendFormat": "hits/s"},
        {"expr": "rate(api_cache_misses_total[2m])", "legendFormat": "misses/s"}
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Cache Hit Rate Trend",
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 8},
      "datasource": {"uid": "prometheus", "type": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1}},
      "options": {"legend": {"displayMode": "list"}},
      "targets": [{"expr": "rate(api_cache_hits_total[5m]) / (rate(api_cache_hits_total[5m]) + rate(api_cache_misses_total[5m]) + 0.001)", "legendFormat": "hit_rate"}]
    }
  ]
}
