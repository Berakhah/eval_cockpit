# Copy to .env (never commit) and fill in per-environment values.
# `make -C polyeval dev` reads this via docker-compose's default env-file lookup.

# HMAC secret used by the API to verify request signatures from the Worker.
# Must be ≥32 bytes. Generate with: openssl rand -hex 32
POLYEVAL_HMAC_SECRET=dev-secret-please-rotate-32bytes-min
